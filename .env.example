# ============================================================================
# FireworkRouter 配置示例
# 真实部署：复制为 .env，运行 python scripts/bootstrap.py 自动生成所有密钥
# ============================================================================

# ============== 基础配置 ==============
APP_ENV=production
LOG_LEVEL=INFO

# API 监听
# - 默认绑 127.0.0.1：只有反向代理（Caddy/Nginx）能访问 — 安全。
# - 改 0.0.0.0 才能外网直接访问（不推荐，没有 HTTPS）。
API_BIND=127.0.0.1
API_PORT=8000

# ============== 数据库（PostgreSQL，docker compose 默认）==============
# Docker compose 模式：保持下面 3 行；PG 容器会用这些参数初始化
POSTGRES_USER=fwr
POSTGRES_PASSWORD=
POSTGRES_DB=fwr

# 应用读的 DATABASE_URL（指向 docker compose 内部的 postgres 容器）
# 不需要改；除非用外部 DB
# DATABASE_URL=postgresql+asyncpg://fwr:YOUR_PG_PASSWORD@postgres:5432/fwr

# === 备选：本地开发用 SQLite（不用 docker compose 跑后端时）===
# DATABASE_URL=sqlite+aiosqlite:///./data/fireworkrouter.db

# ============== Redis（可选）==============
REDIS_URL=redis://redis:6379/0

# ============== 鉴权（bootstrap.py 自动生成；务必保管好）==============
# CLI / 脚本 / CI 用的超级管理员 Bearer Token（永久）
ADMIN_TOKEN=

# 管理后台登录密码（bcrypt 哈希）
ADMIN_PASSWORD_HASH=

# 上游 Fireworks Key 的 Fernet 加密密钥
# ⚠️ 务必备份！丢了所有上游 Key 都解不开！
UPSTREAM_KEY_FERNET_KEY=

# 后台登录 session JWT 签名密钥
SESSION_TOKEN_SECRET=
SESSION_TOKEN_TTL_HOURS=24

# ============== 调度高级（参考 CLIProxyAPI）==============
GATEWAY_MAX_RETRY_CREDENTIALS=3
GATEWAY_MAX_RETRY_INTERVAL_S=30
GATEWAY_DEFAULT_TIMEOUT_S=180
GATEWAY_MAX_RETRY=3

# ============== Fireworks ==============
FIREWORKS_INFERENCE_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_ADMIN_BASE_URL=https://api.fireworks.ai/v1

# ============== 探针 ==============
PROBE_INTERVAL_MINUTES=15
PROBE_CONCURRENCY=20
PROBE_MIN_BALANCE_USD=0.5
# 生产建议 false：启动快 15s；初次部署或调试时可以临时开
PROBE_ON_STARTUP=false

# ============== 上游代理（国内服务器走代理才填）==============
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# ============== Caddy HTTPS（可选）==============
# 启用：docker compose --profile https up -d
# DOMAIN=fwr.example.com
# ACME_EMAIL=you@example.com
