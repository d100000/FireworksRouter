# ============== 基础配置 ==============
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO

# ============== 数据库 ==============
# 默认 SQLite（开发用），生产改 PostgreSQL：
#   postgresql+asyncpg://fwr:fwr@postgres:5432/fwr
DATABASE_URL=sqlite+aiosqlite:///./data/fireworkrouter.db

# ============== Redis（可选，未配置走内存）==============
# REDIS_URL=redis://localhost:6379/0

# ============== 鉴权 ==============
# 管理员 token（CLI / 脚本用的 backdoor），用 openssl rand -hex 32 生成
ADMIN_TOKEN=please-change-this-to-a-random-string

# ============== 加密 ==============
# 上游 Key 的 Fernet 加密密钥（务必备份；丢失后所有上游 Key 都无法解密）。
# 生成方式：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
UPSTREAM_KEY_FERNET_KEY=

# ============== 管理端单密码登录 ==============
# 管理员密码的 bcrypt 哈希（bootstrap.py 会从命令行参数生成）
# 手动生成：python -c "from passlib.context import CryptContext;print(CryptContext(schemes=['bcrypt']).hash('your-password'))"
ADMIN_PASSWORD_HASH=

# 管理端 session JWT 签名密钥（用 openssl rand -hex 48 生成）
SESSION_TOKEN_SECRET=please-change-me-to-a-random-string-of-32-chars-or-more
SESSION_TOKEN_TTL_HOURS=24

# ============== 调度高级 ==============
# 一次请求最多换几把 Key（参考 CLIProxyAPI 的 max-retry-credentials）
GATEWAY_MAX_RETRY_CREDENTIALS=3
# 所有 Key 都在冷却时，最多等冷却恢复多久（秒）
GATEWAY_MAX_RETRY_INTERVAL_S=30

# ============== Fireworks ==============
FIREWORKS_INFERENCE_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_ADMIN_BASE_URL=https://api.fireworks.ai/v1
GATEWAY_DEFAULT_TIMEOUT_S=120
GATEWAY_MAX_RETRY=3

# ============== 探针 ==============
PROBE_INTERVAL_MINUTES=15
PROBE_CONCURRENCY=20
PROBE_MIN_BALANCE_USD=0.5
PROBE_ON_STARTUP=true

# ============== 上游代理（可选）==============
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
